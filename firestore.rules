rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /numbers/{doc} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      // TUZATILDI: endi login qilmasdan faqat "reserved: false -> true" ga
      // o'zgartirish mumkin (buyurtma berilganda). "true -> false" (band
      // qilingan raqamni bo'shatish) FAQAT admin orqali bo'ladi. Shu bilan
      // birov barcha raqamlarni ataylab "band" qilib qo'ya olmaydi va
      // haqiqiy sotilgan raqamlarni qayta "bo'sh" qilolmaydi.
      allow update: if request.auth != null
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reserved'])
            && resource.data.reserved == false
            && request.resource.data.reserved == true);
    }

    match /orders/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /admin_meta/{doc} {
      allow read, write: if request.auth != null;
    }

    match /admin_sessions/{doc} {
      allow create, read: if request.auth != null;
    }

    match /site_settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // TUZATILDI: oldin har kim istalgan maydonni yozishi mumkin edi.
    // Endi faqat "lastSeen" maydonini yozish mumkin (mehmon hisoblagichi
    // uchun), boshqa hech narsani o'zgartirib bo'lmaydi.
    match /active_sessions/{doc} {
      allow create: if request.resource.data.keys().hasOnly(['lastSeen']);
      allow update: if request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen']);
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // TUZATILDI: oldin "read, write: if true" edi — har kim istalgan
    // hujjatni o'chirishi/o'zgartirishi mumkin edi. Endi faqat "counter"
    // hujjatining "totalVisitors" maydonini oshirish mumkin, boshqa
    // hech narsa yozib/o'chirib bo'lmaydi (admin bundan mustasno).
    match /site_stats/{doc} {
      allow read: if true;
      allow create: if request.auth != null
        || (doc == 'counter' && request.resource.data.keys().hasOnly(['totalVisitors']));
      allow update: if request.auth != null
        || (doc == 'counter' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalVisitors']));
      allow delete: if request.auth != null;
    }

    match /promo_codes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // TUZATILDI: oldin "read: if true" butun kolleksiyani (barcha
    // mijozlarning ismi, telefon raqami, manzili, to'lov ma'lumotlari)
    // har kimga ochiq qilib qo'ygan edi. Endi faqat ANIQ bitta shartnoma
    // ID'sini bilgan holda o'sha bitta hujjatni o'qish mumkin ("get"),
    // butun ro'yxatni ko'rish ("list") esa faqat admin uchun.
    // (Kod tomonida ham mos ravishda o'zgartirildi — endi qidiruv
    // to'g'ridan-to'g'ri shartnoma ID'si bo'yicha ishlaydi.)
    match /credit_contracts/{doc} {
      allow get: if true;
      allow list: if request.auth != null;
      allow write: if request.auth != null;
    }

    // TUZATILDI: "list" (butun ro'yxatni ko'rish) endi faqat admin uchun,
    // bitta ma'lum ID bo'yicha tekshirish ("get") esa hammaga ochiq qoladi
    // (kod bunga ehtiyoj sezmaydi ham — mavjud kod allaqachon "get"
    // ishlatadi, o'zgarish shart emas edi).
    match /promo_usage/{doc} {
      allow get, create: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Video sharhlar ("Mijozlarimiz fikri" bo'limi) — hamma o'qiy oladi
    // (saytda ko'rsatilishi kerak), faqat admin qo'shishi/o'chirishi mumkin.
    // Video sharhlar ("Mijozlarimiz fikri" bo'limi) — hamma o'qiy oladi
    // (saytda ko'rsatilishi kerak). Admin video qo'shishi/o'chirishi mumkin.
    // Mijozlar (tizimga kirmasdan) FAQAT "likes" (like bosish) maydonini
    // o'zgartira oladi — boshqa hech qanday maydonni o'zgartira olmaydi.
    match /video_testimonials/{doc} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
    }
  }
}
